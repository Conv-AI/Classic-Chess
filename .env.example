# Shared local settings (copy to .env). Never put the Convai API key here.
VITE_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# Convai API key → copy .env.convai.local.example to .env.convai.local instead.

# Optional: guest Convai character clones (LTM disabled)
# VITE_CONVAI_GUEST_CHARACTER_LEILA=
